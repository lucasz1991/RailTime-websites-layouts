AddDefaultCharset UTF-8
AddCharset UTF-8 .html .php .css .js .csv .svg
Options -MultiViews

DirectoryIndex index.php index.html

# Browser-Caching für statische Assets (entlastet mobile Geräte und Wiederbesuche)
AddType model/gltf-binary .glb
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType video/mp4 "access plus 30 days"
    ExpiresByType model/gltf-binary "access plus 30 days"
    ExpiresByType font/woff2 "access plus 365 days"
</IfModule>
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpe?g|svg|mp4|glb|woff2)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Per-directory rewrites work in the domain root and in every XAMPP
    # subdirectory. A fixed RewriteBase must not be used here.
    # Public, neutral alias for the internally stored logo presentation.
    # The visible URL and all D1/D2 asset URLs stay below /logo-mockup/.
    RewriteRule ^logo-mockup$ index.php?rt_public=logo-mockup&rt_logo_redirect=1 [END,QSA,NC]
    RewriteRule ^logo-mockup/index\.html?$ index.php?rt_public=logo-mockup&rt_logo_redirect=1 [END,QSA,NC]
    RewriteRule ^logo-mockup/$ index.php?rt_public=logo-mockup [END,QSA,NC]
    RewriteRule ^logo-mockup/(d[12]/.+)$ Codex/logo/$1 [END,NC]

    RewriteRule ^layouts/?$ index.php [END,QSA,NC]
    # Plesk may forbid direct requests to PHP scripts other than index.php.
    # Keep index.php as the only public PHP front controller.
    RewriteRule ^layouts/([1-7])/(leistungen|ueber-uns|kontakt|impressum|datenschutz)(?:\.(?:html|php))?/?$ index.php?layout=$1&page=$2 [END,QSA,NC]
    RewriteRule ^layouts/([1-7])(?:/index(?:\.(?:html|php))?)?/?$ index.php?layout=$1 [END,QSA,NC]
</IfModule>
