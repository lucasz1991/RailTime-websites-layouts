AddDefaultCharset UTF-8
AddCharset UTF-8 .html .php .css .js .csv .svg
Options -MultiViews

DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Per-directory rewrites work in the domain root and in every XAMPP
    # subdirectory. A fixed RewriteBase must not be used here.
    RewriteRule ^layouts/?$ index.php [END,QSA,NC]
    RewriteRule ^layouts/([1-7])/(leistungen|ueber-uns|kontakt|impressum|datenschutz)(?:\.(?:html|php))?/?$ router.php?layout=$1&page=$2 [END,QSA,NC]
    RewriteRule ^layouts/([1-7])(?:/index(?:\.(?:html|php))?)?/?$ router.php?layout=$1 [END,QSA,NC]
</IfModule>
